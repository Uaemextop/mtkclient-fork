<?xml version="1.0" encoding="UTF-8"?>
<!--
  mtkclient_driver.wxs
  WiX v3 source for the mtkclient WinUSB driver MSI installer.
  Targets Windows 10/11 x64.

  The MSI:
  1. Installs the test signing certificate to Root + TrustedPublisher stores
  2. Enables test signing mode (bcdedit /set testsigning on)
  3. Stages the signed WinUSB INF + CAT via pnputil /add-driver

  Copyright (c) 2024-2025 mtkclient contributors – GPLv3
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:difx="http://schemas.microsoft.com/wix/DifxAppExtension">

  <Product Id="*"
           Name="mtkclient WinUSB Driver"
           Language="1033"
           Version="1.0.0.0"
           Manufacturer="mtkclient"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Platform="x64"
             Description="WinUSB driver for MediaTek bootrom and preloader USB devices"
             Comments="Enables libusb access to MTK devices on Windows without UsbDk"
             Manufacturer="mtkclient" />

    <!-- Require 64-bit Windows 8.1+ (VersionNT64=603 covers Windows 8.1/10/11
         due to MSI compatibility shims; VersionNT64 is NOT 1000 on Win10/11) -->
    <Condition Message="This installer requires 64-bit Windows 10 or later.">
      <![CDATA[Installed OR VersionNT64 >= 603]]>
    </Condition>

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- ============ Directory layout ============ -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="mtkclient">
          <Directory Id="DRIVERFOLDER" Name="driver" />
        </Directory>
      </Directory>
    </Directory>

    <!-- ============ Driver files ============ -->
    <DirectoryRef Id="DRIVERFOLDER">
      <Component Id="DriverINF" Guid="B1C2D3E4-F5A6-7890-1234-567890ABCDEF" Win64="yes">
        <File Id="mtkclient_inf"
              Source="$(var.DriverDir)\mtkclient.inf"
              KeyPath="yes" />
      </Component>
      <Component Id="DriverCAT" Guid="C2D3E4F5-A6B7-8901-2345-67890ABCDEF0" Win64="yes">
        <File Id="mtkclient_cat"
              Source="$(var.DriverDir)\mtkclient.cat"
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ============ Test certificate (in driver folder) ============ -->
    <DirectoryRef Id="DRIVERFOLDER">
      <Component Id="TestCert" Guid="D3E4F5A6-B7C8-9012-3456-7890ABCDEF01" Win64="yes">
        <File Id="mtkclient_test_cert"
              Source="$(var.DriverDir)\..\output\mtkclient_test_cert.cer"
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ============ Features ============ -->
    <Feature Id="DriverFeature" Title="WinUSB Driver" Level="1"
             Description="Installs the WinUSB driver for MediaTek devices">
      <ComponentRef Id="DriverINF" />
      <ComponentRef Id="DriverCAT" />
      <ComponentRef Id="TestCert" />
    </Feature>

    <!-- ============ Custom Actions ============ -->

    <!-- Install test certificate to Trusted Root store -->
    <SetProperty Id="InstallCertRoot"
                 Before="InstallCertRoot"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]certutil.exe&quot; -addstore Root &quot;[DRIVERFOLDER]mtkclient_test_cert.cer&quot;" />

    <CustomAction Id="InstallCertRoot"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Install test certificate to Trusted Publisher store -->
    <SetProperty Id="InstallCertPublisher"
                 Before="InstallCertPublisher"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]certutil.exe&quot; -addstore TrustedPublisher &quot;[DRIVERFOLDER]mtkclient_test_cert.cer&quot;" />

    <CustomAction Id="InstallCertPublisher"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Enable test signing mode -->
    <SetProperty Id="EnableTestSigning"
                 Before="EnableTestSigning"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]bcdedit.exe&quot; /set testsigning on" />

    <CustomAction Id="EnableTestSigning"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Stage driver via pnputil -->
    <SetProperty Id="InstallDriver"
                 Before="InstallDriver"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]pnputil.exe&quot; /add-driver &quot;[DRIVERFOLDER]mtkclient.inf&quot; /install" />

    <CustomAction Id="InstallDriver"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Uninstall: remove driver -->
    <SetProperty Id="UninstallDriver"
                 Before="UninstallDriver"
                 Sequence="execute"
                 Value="&quot;[SystemFolder]pnputil.exe&quot; /delete-driver &quot;[DRIVERFOLDER]mtkclient.inf&quot; /uninstall /force" />

    <CustomAction Id="UninstallDriver"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="InstallCertRoot"      After="InstallFiles">NOT Installed</Custom>
      <Custom Action="InstallCertPublisher" After="InstallCertRoot">NOT Installed</Custom>
      <Custom Action="EnableTestSigning"    After="InstallCertPublisher">NOT Installed</Custom>
      <Custom Action="InstallDriver"        After="EnableTestSigning">NOT Installed</Custom>
      <Custom Action="UninstallDriver"      Before="RemoveFiles">REMOVE="ALL"</Custom>
    </InstallExecuteSequence>

    <!-- WiX default UI (minimal) -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.DriverDir)\..\LICENSE.rtf" />

  </Product>
</Wix>
