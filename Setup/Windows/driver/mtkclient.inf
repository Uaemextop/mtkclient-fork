;
; Open-source WinUSB driver for MediaTek USB devices on Windows 11 x64.
; Covers all SP driver device modes: Bootrom (BROM), Preloader,
; Download Agent (DA), Meta mode, and composite VCOM interfaces.
;
; VID/PID values sourced from official MediaTek SP Drivers 20160804
; and extended with mtkclient-specific device identifiers.

[Version]
Signature   = "$Windows NT$"
Class       = USBDevice
ClassGUID   = {88BAE032-5A81-49f0-BC3D-A4FF138216D6}
Provider    = %ProviderName%
CatalogFile = mtkclient.cat
DriverVer   = 03/13/2026,2.0.0.0
PnpLockDown = 1

[Manufacturer]
%ManufacturerName% = Standard,NTamd64

; ===========================================================================
; x64 Device List
; ===========================================================================
[Standard.NTamd64]

; ---- Bootrom (BROM) ----
%DevName_Brom%          = USB_Install, USB\VID_0E8D&PID_0003

; ---- Preloader ----
%DevName_Preloader%     = USB_Install, USB\VID_0E8D&PID_2000

; ---- Download Agent (DA) ----
%DevName_DA%            = USB_Install, USB\VID_0E8D&PID_2001

; ---- Meta Mode / Generic VCOM (single-interface) ----
%DevName_Meta%          = USB_Install, USB\VID_0E8D&PID_2007
%DevName_Preloader%     = USB_Install, USB\VID_0E8D&PID_20FF
%DevName_Preloader%     = USB_Install, USB\VID_0E8D&PID_3000
%DevName_Preloader%     = USB_Install, USB\VID_0E8D&PID_6000

; ---- Bootloader (Android) ----
%DevName_Bootloader%    = USB_Install, USB\VID_0E8D&PID_2024

; ---- Composite VCOM interfaces (from SP Driver cdc-acm.inf) ----
