; ===========================================================================
; Installation sections
; ===========================================================================

[USB_Install]
Include = winusb.inf
Needs   = WINUSB.NT

[USB_Install.Services]
Include    = winusb.inf
AddService = WinUSB,0x00000002,WinUSB_ServiceInstall

[WinUSB_ServiceInstall]
DisplayName   = %WinUSB_SvcDesc%
ServiceType   = 1  ; SERVICE_KERNEL_DRIVER
StartType     = 3  ; SERVICE_DEMAND_START
ErrorControl  = 1  ; SERVICE_ERROR_NORMAL
ServiceBinary = %12%\WinUSB.sys

[USB_Install.Wdf]
KmdfService = WINUSB, WinUSB_Install

[WinUSB_Install]
KmdfLibraryVersion = 1.11

[USB_Install.HW]
AddReg = Dev_AddReg

[Dev_AddReg]
HKR,,DeviceInterfaceGUIDs,0x00010000,"{13EB360B-BC1E-46CB-B606-B4884B5E8B23}"

[USB_Install.CoInstallers]
AddReg    = CoInstallers_AddReg
CopyFiles = CoInstallers_CopyFiles

[CoInstallers_AddReg]
HKR,,CoInstallers32,0x00010000,"WdfCoInstaller01011.dll,WdfCoInstaller"

[CoInstallers_CopyFiles]
WdfCoInstaller01011.dll

[DestinationDirs]
CoInstallers_CopyFiles = 11

; ===========================================================================
; Source media
; ===========================================================================

[SourceDisksNames]
1 = %DiskName%

[SourceDisksFiles]
WdfCoInstaller01011.dll = 1

; ===========================================================================
; Strings
; ===========================================================================

[Strings]
ProviderName        = "mtkclient"
ManufacturerName    = "MediaTek Inc."
DevName_Brom        = "MediaTek USB Port (BROM)"
DevName_Preloader   = "MediaTek PreLoader USB VCOM"
DevName_DA          = "MediaTek DA USB VCOM"
DevName_Meta        = "MediaTek Meta Mode USB VCOM"
DevName_Bootloader  = "MediaTek Bootloader Interface"
DevName_VCOM        = "MediaTek USB VCOM"
DevName_ADB         = "MediaTek ADB Interface"
DevName_LG          = "LG Preloader Interface"
DevName_OPPO        = "OPPO Preloader Interface"
WinUSB_SvcDesc      = "WinUSB Driver for MTK Devices"
DiskName            = "mtkclient WinUSB Driver Disk"
