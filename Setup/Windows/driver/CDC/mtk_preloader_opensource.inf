;
; mtk_preloader_opensource.inf
;
; Opensource Windows 11 driver for MediaTek Preloader / BROM DA / Meta Mode
; USB CDC ACM serial ports.
;
; This INF maps MediaTek USB hardware IDs to the Windows inbox usbser.sys
; (USB Serial) driver — no custom kernel binary is needed.
;
; Based on Capstone analysis of the proprietary usb2ser.sys (MediaTek SP
; Driver 20160804).  Functionally equivalent: the proprietary driver is a
; standard CDC ACM class driver and usbser.sys provides the same protocol.
;
; Copyright (c) 2026 — Released under MIT License
; Repository: github.com/Uaemextop/mtk-loader-drivers-opensource-win11
;

[Version]
Signature   = "$Windows NT$"
Class       = Ports
ClassGuid   = {4D36E978-E325-11CE-BFC1-08002BE10318}
Provider    = %ProviderName%
DriverVer   = 03/13/2026,1.0.0.0
CatalogFile = mtk_preloader_opensource.cat
PnpLockdown = 1

[Manufacturer]
%ProviderName% = DeviceList, NTamd64, NTx86

[DestinationDirs]
DefaultDestDir = 12

; ==========================================================================
;  x64 Device List
