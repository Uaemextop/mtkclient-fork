%MTK_MODEM%       = MTK_CDC_Install, USB\VID_0E8D&PID_2051&MI_00
%MTK_MODEM%       = MTK_CDC_Install, USB\VID_0E8D&PID_2052&MI_00
%MTK_VCOM%        = MTK_CDC_Install, USB\VID_0E8D&PID_2052&MI_01
%MTK_MODEM%       = MTK_CDC_Install, USB\VID_0E8D&PID_2053&MI_00
%MTK_MODEM%       = MTK_CDC_Install, USB\VID_0E8D&PID_2054&MI_00
%MTK_VCOM%        = MTK_CDC_Install, USB\VID_0E8D&PID_2054&MI_03
%MTK_MODEM%       = MTK_CDC_Install, USB\VID_0E8D&PID_2063&MI_00
%MTK_VCOM%        = MTK_CDC_Install, USB\VID_0E8D&PID_2063&MI_01
%MTK_ETS%         = MTK_CDC_Install, USB\VID_0E8D&PID_2063&MI_03
%MTK_ELT%         = MTK_CDC_Install, USB\VID_0E8D&PID_2063&MI_05
%MTK_VCOM%        = MTK_CDC_Install, USB\VID_0E8D&PID_2064&MI_03
%MTK_ETS%         = MTK_CDC_Install, USB\VID_0E8D&PID_2064&MI_05
%MTK_ELT%         = MTK_CDC_Install, USB\VID_0E8D&PID_2064&MI_07

; ==========================================================================
;  Source disk layout — NO custom binary needed, uses Windows inbox usbser.sys
; ==========================================================================
[SourceDisksNames]
1 = %DiskName%

[SourceDisksFiles]
; intentionally empty — no files to copy, usbser.sys is inbox

; ==========================================================================
;  Install section — x86 (32-bit)
; ==========================================================================
[MTK_CDC_Install.NT]
Include = mdmcpq.inf, usbser.inf
Needs   = UsbSer_Install
AddReg  = MTK_CDC_AddReg

[MTK_CDC_Install.NT.Services]
Include    = usbser.inf
Needs      = UsbSer_Install.Services

[MTK_CDC_Install.NT.HW]
AddReg = MTK_CDC_HwAddReg

; ==========================================================================
;  Install section — x64 (64-bit)
; ==========================================================================
[MTK_CDC_Install.NTamd64]
; mdmcpq.inf provides modem/COM port registry settings, usbser.inf provides the inbox USB serial driver
Include = mdmcpq.inf, usbser.inf
Needs   = UsbSer_Install
AddReg  = MTK_CDC_AddReg

[MTK_CDC_Install.NTamd64.Services]
Include    = usbser.inf
Needs      = UsbSer_Install.Services

[MTK_CDC_Install.NTamd64.HW]
AddReg = MTK_CDC_HwAddReg

; ==========================================================================
;  Registry settings
; ==========================================================================
[MTK_CDC_HwAddReg]
HKR,,DriverInfo,,"USB to Com Port registry key"
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GRGWGX;;;BA)(A;;GRGWGX;;;WD)(A;;GRGWGX;;;RC)"

[MTK_CDC_AddReg]
HKR,,Installer32,,"MsPorts.Dll,PortsClassInstaller"
HKR,,EnumPropPages32,,"MsPorts.dll,SerialPortPropPageProvider"

; ==========================================================================
;  Strings
; ==========================================================================
[Strings]
ProviderName  = "MTK Loader Drivers Opensource"
DiskName      = "MediaTek USB Driver Installation Disk"
MTK_BOOTROM   = "MediaTek USB Port (BROM)"
MTK_PRELOADER = "MediaTek PreLoader USB VCOM Port"
MTK_DA        = "MediaTek DA USB VCOM Port"
MTK_VCOM      = "MediaTek USB VCOM Port"
MTK_MODEM     = "MediaTek Modem Port"
MTK_ELT       = "MediaTek ELT Port"
MTK_ETS       = "MediaTek ETS Port"
MTK_AT        = "MediaTek AT Command Port"
