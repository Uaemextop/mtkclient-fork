; -------------------------------------------------------------------
;  Install sections — inbox usbser.sys (replaces legacy usb2ser.sys)
;
;  Port speed configuration for mtkclient:
;    BROM handshake : 115200 bps  (8-N-1, no flow control)
;    DA high-speed  : 921600 bps  (negotiated at runtime)
;    Supported range: 300 - 921600 bps
; -------------------------------------------------------------------

[DriverInstall]
Include   = mdmcpq.inf, msports.inf
CopyFiles = FakeModemCopyFileSection
AddReg    = SerialPort_AddReg

[DriverInstall.NTamd64]
Include   = mdmcpq.inf, msports.inf
CopyFiles = FakeModemCopyFileSection
AddReg    = SerialPort_AddReg

[DriverInstall.NTamd64.Services]
Include    = mdmcpq.inf
AddService = usbser,0x00000002,usbser_ServiceInstall

[usbser_ServiceInstall]
DisplayName   = %SerialDriverDesc%
ServiceType   = 1
StartType     = 3
ErrorControl  = 1
ServiceBinary = %12%\usbser.sys

[DriverInstall.NTamd64.HW]
AddReg = SerialHw_AddReg

[SerialHw_AddReg]
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GRGWGX;;;BA)(A;;GRGWGX;;;WD)(A;;GRGWGX;;;RC)"
HKR,,IdleInWorkingState,0x00010001,0
HKR,,DeviceSelectiveSuspended,0x00010001,0

; -------------------------------------------------------------------
;  COM port default settings (mtkclient optimal values)
; -------------------------------------------------------------------
[SerialPort_AddReg]
HKR,,PortSubClass,1,01
; Default baud rate: 115200 (BROM/Preloader handshake speed)
HKR,,BaudRate,0x00010001,0x0001C200
; Maximum baud rate: 921600 (DA high-speed transfer)
HKR,,MaxBaudRate,0x00010001,0x000E1000
; 8 data bits
HKR,,DataBits,0x00010001,8
; No parity (0 = None)
HKR,,Parity,0x00010001,0
; 1 stop bit (0 = 1 stop bit in Windows encoding)
HKR,,StopBits,0x00010001,0
; No flow control
HKR,,FlowControl,0x00010001,0
; Latency timer: 2 ms (low latency for mtkclient handshake)
HKR,,LatencyTimer,0x00010001,2
; COM port property page
HKR,,Installer32,,"MsPorts.Dll,PortsClassInstaller"
HKR,,EnumPropPages32,,"MsPorts.dll,SerialPortPropPageProvider"
; Idle settings — disable idle to avoid disconnects during flash
HKR,,IdleTime,0x00010001,0
HKR,,IdleEnable,0x00010001,0

[DestinationDirs]
DefaultDestDir          = 13   ; Driver Store (DCH compliant)
FakeModemCopyFileSection = 12

; -------------------------------------------------------------------
;  Strings (kept same names as original MTK cdc-acm.inf)
; -------------------------------------------------------------------

[Strings]
MEDIATEK         = "MediaTek Inc."
SerialDriverDesc = "MediaTek USB Serial Port (mtkclient)"
VCOM_BOOTROM     = "MediaTek USB Port (BROM)"
VCOM_PRELOADER   = "MediaTek PreLoader USB VCOM Port"
VCOM_DA          = "MediaTek DA USB VCOM Port"
VCOM             = "MediaTek USB VCOM Port"
MODEM            = "MediaTek Modem Port"
ELT              = "MediaTek ELT Port"
ETS              = "MediaTek ETS Port"
AT               = "MediaTek AT Port"
