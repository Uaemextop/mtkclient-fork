;
; cdc-acm.inf - Serial (COM port) driver for MediaTek USB VCOM
;
; Based on original MTK SP Drivers 20160804 cdc-acm.inf.
; Modified for Windows 10/11 x64: replaces legacy usb2ser.sys with
; the inbox usbser.sys (available since Windows 10 1803).
; Original usb2ser.sys kept in CDC/x64/ and CDC/x86/ for reference.
;
; Port speed configuration for mtkclient:
;   BROM handshake : 115200 bps  (8-N-1, no flow control)
;   DA high-speed  : 921600 bps  (negotiated at runtime)
;

[Version]
Signature   = "$Windows NT$"
Class       = Ports
ClassGuid   = {4D36E978-E325-11CE-BFC1-08002BE10318}
Provider    = %MEDIATEK%
CatalogFile = cdc-acm.cat
DriverVer   = 03/13/2026,3.0.2026.0
PnpLockdown = 1

[Manufacturer]
%MEDIATEK% = DeviceList, NTamd64

[DeviceList.NTamd64]
; ==================== BootRom & Preloader VCOM (whole device) ==========
%VCOM_BOOTROM%=DriverInstall, USB\Vid_0e8d&Pid_0003
