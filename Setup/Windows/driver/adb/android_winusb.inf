%CompositeAdbInterface%     = USB_Install, USB\VID_22D9&PID_2769&MI_01

; =====================================================================
;  Install sections — inbox WinUSB, no CoInstallers needed on Win10+
;
;  Compared to Google r13 original:
;    - Removed CoInstallers (WdfCoInstaller, WinUSBCoInstaller2)
;    - Removed SourceDisksNames/SourceDisksFiles (no DLLs to ship)
;    - Removed USB_Install.Wdf (inbox KMDF on Win10+)
;    - Added PnpLockdown=1 + DefaultDestDir=13 (DCH compliance)
;    - Added selective suspend disable + security ACL
; =====================================================================

[USB_Install]
Include = winusb.inf
Needs   = WINUSB.NT

[USB_Install.Services]
Include    = winusb.inf
AddService = WinUSB,0x00000002,WinUSB_ServiceInstall

[WinUSB_ServiceInstall]
DisplayName   = %WinUSB_SvcDesc%
ServiceType   = 1
StartType     = 3
ErrorControl  = 1
ServiceBinary = %12%\WinUSB.sys

[USB_Install.HW]
AddReg = Dev_AddReg

[Dev_AddReg]
; Standard ADB DeviceInterfaceGUID — required for adb.exe to find the device
HKR,,DeviceInterfaceGUIDs,0x10000,"{F72FE0D4-CBCB-407d-8814-9ED673D0DD6B}"
; Also register mtkclient GUID so libusb/WinUSB backend can claim the device
HKR,,DeviceInterfaceGUIDs,0x10008,"{1D0C3B4F-2E1A-4A32-9C3F-5D6B7E8F9A0B}"
; Selective suspend — disable to prevent device disconnects during flash
HKR,,DeviceSelectiveSuspended,0x00010001,0
HKR,,SelectiveSuspendEnabled,0x00010001,0
; Allow user-mode access for adb / libusb / WinUSB
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GRGWGX;;;BA)(A;;GRGWGX;;;WD)(A;;GRGWGX;;;RC)"

; ── ADB VID registration ──────────────────────────────────────────
; Write all supported VIDs to the system-wide adb_usb.ini so that
; both old and new adb.exe versions can detect these devices.
; (Replaces the manual ADB_add_VID.bat from MTK SP Drivers 20160804)
HKLM,"SOFTWARE\Android USB Devices","VID_0E8D",,"0x0E8D"
HKLM,"SOFTWARE\Android USB Devices","VID_18D1",,"0x18D1"
HKLM,"SOFTWARE\Android USB Devices","VID_0FCE",,"0x0FCE"
HKLM,"SOFTWARE\Android USB Devices","VID_1004",,"0x1004"
HKLM,"SOFTWARE\Android USB Devices","VID_22D9",,"0x22D9"

[DestinationDirs]
DefaultDestDir = 13   ; Driver Store (DCH compliant)

; =====================================================================
;  Strings
; =====================================================================

[Strings]
ProviderName                = "Google, Inc."
MTKName                     = "MediaTek Inc."
SonyName                    = "Sony Mobile Communications"
LGName                      = "LG Electronics"
OPPOName                    = "OPPO Mobile"
SingleAdbInterface          = "Android ADB Interface"
CompositeAdbInterface       = "Android Composite ADB Interface"
SingleBootLoaderInterface   = "Android Bootloader Interface"
WinUSB_SvcDesc              = "Android USB Driver"
ClassName                   = "Android Device"
MTK_BROM                    = "MediaTek BROM Interface"
MTK_Preloader               = "MediaTek Preloader Interface"
MTK_DA                      = "MediaTek DA Interface"
MTK_MTP                     = "MediaTek MTP Interface"
Sony_BROM                   = "Sony BROM Interface"
LG_Preloader                = "LG Preloader Interface"
OPPO_Preloader              = "OPPO Preloader Interface"
