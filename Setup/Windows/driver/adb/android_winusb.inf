;
; Android WinUsb driver installation.
;
; Based on Google USB Driver r13 (android_winusb.inf).
; Modified to add MediaTek device support for BROM, Preloader, DA,
; ADB, Bootloader, and MTP modes.
;
; Changes from Google original:
;   - Added [MediaTek.NTamd64] section with all MTK VID_0E8D entries
;     from MTK SP Drivers 20160804 android_winusb.inf
;   - Added [Sony.NTamd64], [LG.NTamd64], [OPPO.NTamd64] sections
;   - Added MTK MTP entries from original wpdmtp.inf
;   - Added MTK BROM/Preloader/DA whole-device entries
;   - Removed legacy CoInstallers (not needed on Windows 10+)
;   - Added PnpLockdown=1, DefaultDestDir=13 for DCH compliance
;   - Added selective suspend disable + security ACL
;   - x64-only (NTamd64) for Windows 10/11
;
[Version]
Signature           = "$Windows NT$"
Class               = AndroidUsbDeviceClass
ClassGuid           = {3F966BD9-FA04-4ec5-991C-D326973B5128}
Provider            = %ProviderName%
DriverVer           = 03/13/2026,13.0.0.1
CatalogFile         = android_winusb.cat
PnpLockdown         = 1

;
; This section seems to be required for WinUsb driver installation.
; If this section is removed the installer will report an error
; "Required section not found in INF file".
;
[ClassInstall32]
Addreg = AndroidWinUsbClassReg

[AndroidWinUsbClassReg]
HKR,,,0,%ClassName%
HKR,,Icon,,-1

[Manufacturer]
%ProviderName% = Google, NTamd64
%MTKName%      = MediaTek, NTamd64
%SonyName%     = Sony, NTamd64
%LGName%       = LG, NTamd64
%OPPOName%     = OPPO, NTamd64

; =====================================================================
;  Google devices (original entries from android_winusb.inf r13)
; =====================================================================
[Google.NTamd64]

;Google Nexus One
%SingleAdbInterface%        = USB_Install, USB\VID_18D1&PID_0D02
%CompositeAdbInterface%     = USB_Install, USB\VID_18D1&PID_0D02&MI_01
%SingleAdbInterface%        = USB_Install, USB\VID_18D1&PID_4E11
%CompositeAdbInterface%     = USB_Install, USB\VID_18D1&PID_4E12&MI_01

;Google Nexus S
